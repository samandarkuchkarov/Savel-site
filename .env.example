# Admin panel (см. README Savel_server)
SAVEL_API_URL=http://localhost:4000
# Публичный origin API для картинок в админке: их грузит БРАУЗЕР, а он не достучится
# до loopback SAVEL_API_URL. В проде = https://api.savel.uz. Пусто → берётся
# SAVEL_API_URL (годится для локальной разработки).
PUBLIC_API_URL=
ADMIN_TOKEN=change-me-long-random
ADMIN_PANEL_PASSWORD=change-me

# То же значение, что INTERNAL_PROXY_SECRET у Savel_server. Next.js подписывает им
# проброс реального IP посетителя лендингов (invite) — чтобы rate limit считал по
# посетителю, а не по общему IP SSR-сервера. Server-only секрет: НЕ NEXT_PUBLIC_*,
# в браузер не уходит. Пусто → IP не пробрасываем (API лимитирует по своему req.ip).
INTERNAL_PROXY_SECRET=change-me-long-random

# Сколько доверенных прокси перед Next.js (наш Caddy = 1). Если добавите
# Cloudflare/ещё один прокси — увеличьте, иначе реальный IP определится неверно.
TRUSTED_PROXY_HOPS=1
